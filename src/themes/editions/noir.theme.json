{
  "meta": {
    "id": "noir",
    "displayName": "Noir",
    "version": "1.0.0",
    "summary": "High-contrast black-on-charcoal theme with a single neon accent. Demonstrates dark-mode token swaps over the tabletop foundation.",
    "tags": ["dark", "high-contrast"]
  },
  "extends": "tabletop",
  "tokens": {
    "color": {
      "bg": "#0d0d10",
      "surface": "#16161b",
      "ink": "#f4f4f6",
      "inkMuted": "#9a9aa3",
      "accent": "#e0d000",
      "rule": "#2a2a32",
      "success": "#5dd39e",
      "warning": "#f5a524",
      "danger": "#ff5d5d",
      "extras": {
        "neon": "#9bff8a",
        "shadowDeep": "#000000"
      }
    },
    "typography": {
      "fontFamilySans": "\"Inter\", \"Helvetica Neue\", Arial, sans-serif"
    },
    "shadow": {
      "card": "0 1px 2px rgba(0, 0, 0, 0.6), 0 4px 16px rgba(0, 0, 0, 0.45)",
      "popover": "0 8px 24px rgba(0, 0, 0, 0.7), 0 24px 64px rgba(0, 0, 0, 0.5)"
    }
  }
}
